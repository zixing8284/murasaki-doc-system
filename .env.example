# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema


#-----------DEVELOPMENT------------

# Prisma Database URL
DATABASE_URL="file:./dev.db"

# openssl rand -base64 32
SESSION_SECRET=your-session-secret-here

BCRYPT_SALT_ROUNDS=5

# Guard for seed script: must be "true" to run, otherwise exits immediately.
# Set to "true" in development to populate demo data; set to "false" or omit in production.
SEED_DEVELOPMENT=true

# file store path
FILE_PATH=/file


#-----------PRODUCTION------------

# DATABASE_URL="file:../database/murasaki.db"

# SESSION_SECRET=your-session-secret-here

# BCRYPT_SALT_ROUNDS=5

# SEED_DEVELOPMENT=false

# FILE_PATH=/file/


#-----------DOCKER------------
# docker-compose.yml reads this file via env_file.
# DATABASE_URL and FILE_PATH are overridden in docker-compose.yml
# to match container paths. Other variables are used as-is.
